    },
    "./icon-button": {
      "types": "./dist/icon-button.d.ts",
      "import": "./dist/icon-button.js"
    },
    "./magnetic-button": {
      "types": "./dist/magnetic-button.d.ts",
      "import": "./dist/magnetic-button.js"
    },
