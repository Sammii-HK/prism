    "./shimmer-text": {
      "types": "./dist/shimmer-text.d.ts",
      "import": "./dist/shimmer-text.js"
    },
    "./skeleton": {
      "types": "./dist/skeleton.d.ts",
      "import": "./dist/skeleton.js"
    },
    "./spotlight-card": {
      "types": "./dist/spotlight-card.d.ts",
      "import": "./dist/spotlight-card.js"
    },
    "./spring-toggle": {
      "types": "./dist/spring-toggle.d.ts",
      "import": "./dist/spring-toggle.js"
