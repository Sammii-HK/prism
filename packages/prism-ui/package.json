    },
    "./avatar": {
      "types": "./dist/avatar.d.ts",
      "import": "./dist/avatar.js"
    },
    "./floating-dock": {
      "types": "./dist/floating-dock.d.ts",
      "import": "./dist/floating-dock.js"
    },
    "./fluid-tooltip": {
      "types": "./dist/fluid-tooltip.d.ts",
      "import": "./dist/fluid-tooltip.js"
    },
    "./glow-badge": {
      "types": "./dist/glow-badge.d.ts",
      "import": "./dist/glow-badge.js"
    },
    "./glow-checkbox": {
      "types": "./dist/glow-checkbox.d.ts",
      "import": "./dist/glow-checkbox.js"
    },
    "./glow-input": {
      "types": "./dist/glow-input.d.ts",
      "import": "./dist/glow-input.js"
